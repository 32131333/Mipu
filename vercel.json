{
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://mipuwu.mooo.com/api"
    },
    {
      "source": "/api/",
      "destination": "https://mipuwu.mooo.com/api/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://mipuwu.mooo.com/api/:path*"
    },
    {
      "source": "/media",
      "destination": "https://mipuwu.mooo.com/media"
    },
    {
      "source": "/media/",
      "destination": "https://mipuwu.mooo.com/media/"
    },
    {
      "source": "/media/:path*",
      "destination": "https://mipuwu.mooo.com/media/:path*"
    },
    {
      "source": "/sitemap.xml", "destination": "https://mipuwu.mooo.com/sitemap.xml"
    },
    { 
      "source": "/sitemap:id.xml", "destination": "https://mipuwu.mooo.com/sitemap:id.xml"
    }
  ],
  "redirects": [
    {
      "source": "/socket.io",
      "destination": "https://mipuwu.mooo.com/api/socket.io"
    },
    {
      "source": "/socket.io/",
      "destination": "https://mipuwu.mooo.com/api/socket.io/"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://mipuwu.mooo.com/api/socket.io/:path*"
    }
  ]
}
